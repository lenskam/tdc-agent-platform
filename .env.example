# Server Configuration
PORT=8000
ENVIRONMENT=development # development | production

# Docker Compose Port Mappings (used by docker-compose.yml)
# These control the external ports exposed on the host machine
API_PORT=8001
DASHBOARD_PORT=3001
POSTGRES_PORT=5434
REDIS_PORT=6380

# Database Configuration
POSTGRES_USER=tdc_user
POSTGRES_PASSWORD=tdc_password
POSTGRES_DB=tdc_agent_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis Configuration (internal container port)
REDIS_HOST=redis
REDIS_PORT=6379

# Vector Store
CHROMA_PERSIST_DIRECTORY=./chroma_db

# LLM Configuration
# Options: openai, ollama, anthropic
DEFAULT_LLM_PROVIDER=openai
# For Local LLM (Ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# API Keys (Leave empty if using Local LLM only)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...

# Tool Configuration
GOOGLE_DRIVE_CREDENTIALS_FILE=credentials.json

# Security
SECRET_KEY=your-secret-key-change-in-production

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
