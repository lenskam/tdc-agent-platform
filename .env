# Server Configuration
ENVIRONMENT=development
DOMAIN=agents.tdcconsultingsarl.com

# Database Configuration (use internal Docker ports)
POSTGRES_USER=tdc_user
POSTGRES_PASSWORD=tdc_password
POSTGRES_DB=tdc_agent_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Docker Compose Port Mappings (external ports)
API_PORT=8001
DASHBOARD_PORT=3001
EXTERNAL_POSTGRES_PORT=5435
REDIS_PORT=6381

# API URL for internal services
API_URL=agents.tdcconsultingsarl.com/api

NEXT_PUBLIC_API_URL=agents.tdcconsultingsarl.com/api

# Redis Configuration (use internal Docker port)
REDIS_HOST=redis
REDIS_PORT=6379

# Vector Store
CHROMA_PERSIST_DIRECTORY=/app/chroma_db

# LLM Configuration
DEFAULT_LLM_PROVIDER=openai
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...

# Tool Configuration
GOOGLE_DRIVE_CREDENTIALS_FILE=credentials.json

# Security
SECRET_KEY=your-secret-key-change-in-production

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
